{

  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "module": "commonjs",
    "target": "es2020",
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*", "index.ts"] // ← le dice a TypeScript dónde están los archivos
  ,"ts-node": {
    "files": true
  }
}